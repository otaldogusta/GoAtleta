{
  "name": "goatleta",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File ./script/start_clean_local.ps1 web",
    "build": "expo export -p web",
    "test": "jest --passWithNoTests",
    "test:e2e": "node scripts/test-e2e.js",
    "test:core": "jest src/core/consultation/__tests__ src/copilot/__tests__ src/api/__tests__ src/push/__tests__ supabase/functions/assistant/__tests__ --passWithNoTests",
    "lint": "expo lint",
    "typecheck:core": "tsc -p tsconfig.check.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app-check.json --noEmit",
    "check:activity-catalog-media": "node scripts/check-activity-catalog-media.js",
    "check:architecture": "node scripts/check-architecture-hygiene.js",
    "check:architecture:strict": "node scripts/check-architecture-hygiene.js --strict",
    "check:architecture:report": "node scripts/check-architecture-hygiene.js --report",
    "check:perf-hygiene": "node scripts/check-perf-hygiene.js",
    "check:perf-hygiene:strict": "node scripts/check-perf-hygiene.js --strict",
    "check:org-scope": "node scripts/check-org-scope.js",
    "test:architecture": "jest scripts/architecture-hygiene/__tests__/analyzer.test.ts --runInBand",
    "tools:check": "npm run check:encoding && npm run check:edge-jwt && npm run check:org-scope",
    "release:check": "npm run lint && npm run check:org-scope",
    "release:check:core": "npm run check:encoding && npm run typecheck:core && npm run test:core && npm run check:org-scope",
    "update:preview": "npm run release:check:core && eas update --channel preview --auto",
    "update:production": "npm run release:check:core && eas update --channel production --auto",
    "update:promote": "eas update:promote",
    "check:encoding": "node scripts/check-encoding.js",
    "check:edge-jwt": "node scripts/check-edge-jwt.js",
    "intake:import": "node scripts/import-athlete-intake.js",
    "intake:upsert": "node scripts/import-athlete-intake.js --upsert",
    "intake:auto": "node scripts/run-intake-import.js",
    "intake:auto:upsert": "node scripts/run-intake-import.js --upsert",
    "figma:colors": "node scripts/sync-figma-colors.js",
    "postinstall": "patch-package && node scripts/check-yoga-patch.js"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.6.2",
    "@swc/helpers": "^0.5.18",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.3.1",
    "expo": "~56.0.16",
    "expo-calendar": "~56.0.9",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.23",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.22",
    "expo-image-picker": "~56.0.21",
    "expo-intent-launcher": "~56.0.4",
    "expo-keep-awake": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-local-authentication": "~56.0.4",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.21",
    "expo-print": "~56.0.4",
    "expo-router": "~56.2.15",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.22",
    "expo-splash-screen": "~56.0.13",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.22",
    "expo-web-browser": "~56.0.5",
    "lodash": "^4.17.21",
    "lodash.isempty": "^4.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-jest": "^29.7.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "xcode": {
      "uuid": "^11.1.1"
    },
    "image-size": "1.2.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nfc-manager"
        ]
      }
    }
  },
  "private": true
}
