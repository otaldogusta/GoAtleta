{
  "name": "goatleta",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export -p web",
    "test": "jest --passWithNoTests",
    "test:core": "jest src/copilot/__tests__ src/api/__tests__ src/push/__tests__ supabase/functions/assistant/__tests__ --passWithNoTests",
    "test:science-scenarios": "jest src/core/scenarios --passWithNoTests",
    "test:exercise-media": "jest src/exercise-media --passWithNoTests",
    "test:exercise-media:dev": "jest src/exercise-media/__tests__/dev-exercise-media-assets.test.ts --passWithNoTests",
    "test:exercise-media:approval": "jest src/exercise-media/__tests__/exercise-media-approval.test.ts --passWithNoTests",
    "test:exercise-media:supabase": "jest src/exercise-media/stores/__tests__/supabase-exercise-media-store.test.ts src/exercise-media/__tests__/bootstrap-exercise-media-store.test.ts --passWithNoTests",
    "test:media-generation": "jest src/media-generation --passWithNoTests",
    "test:media-generation:handoff": "jest src/media-generation/handoff --passWithNoTests",
    "test:media-generation:queue": "jest src/media-generation/queue --passWithNoTests",
    "test:media-generation:registry": "jest src/media-generation/__tests__/register-generated-media-assets.test.ts --passWithNoTests",
    "test:pdf-media": "jest src/pdf --passWithNoTests",
    "test:e2e:web": "playwright test",
    "test:e2e:web:ui": "playwright test --ui",
    "test:e2e:mobile": "maestro test e2e/mobile",
    "lint": "expo lint",
    "typecheck:core": "tsc -p tsconfig.check.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app-check.json --noEmit",
    "check:perf-hygiene": "node scripts/check-perf-hygiene.js",
    "check:perf-hygiene:strict": "node scripts/check-perf-hygiene.js --strict",
    "check:org-scope": "node scripts/check-org-scope.js",
    "release:check": "npm run lint && npm run check:org-scope",
    "release:check:core": "npm run check:encoding && npm run typecheck:core && npm run test:core && npm run check:org-scope",
    "update:preview": "npm run release:check:core && eas update --channel preview --auto",
    "update:production": "npm run release:check:core && eas update --channel production --auto",
    "update:promote": "eas update:promote",
    "check:encoding": "node scripts/check-encoding.js",
    "check:dead-code": "knip --no-exit-code",
    "check:architecture": "depcruise src --config .dependency-cruiser.cjs",
    "check:architecture:graph": "depcruise src --config .dependency-cruiser.cjs --output-type dot > dependency-graph.dot",
    "tools:check": "npm run check:architecture",
    "check:edge-jwt": "node scripts/check-edge-jwt.js",
    "intake:import": "node scripts/import-athlete-intake.js",
    "intake:upsert": "node scripts/import-athlete-intake.js --upsert",
    "intake:auto": "node scripts/run-intake-import.js",
    "intake:auto:upsert": "node scripts/run-intake-import.js --upsert",
    "figma:colors": "node scripts/sync-figma-colors.js",
    "sentry:info": "sentry-cli info",
    "sentry:releases": "sentry-cli releases list",
    "qr:generate": "node scripts/generate-qr.js",
    "media:prepare-video": "node scripts/media/prepare-video.js",
    "goatleta:plan": "node scripts/goatleta-plan.js",
    "postinstall": "patch-package && node scripts/check-yoga-patch.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/react-native": "~7.11.0",
    "@swc/helpers": "^0.5.18",
    "dotenv": "^17.3.1",
    "expo": "~55.0.15",
    "expo-calendar": "~55.0.14",
    "expo-camera": "~55.0.15",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.27",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-intent-launcher": "~55.0.12",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.13",
    "expo-local-authentication": "~55.0.13",
    "expo-modules-core": "^55.0.22",
    "expo-network": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-print": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-updates": "~55.0.20",
    "expo-web-browser": "~55.0.14",
    "lodash": "^4.17.21",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "xlsx": "^0.18.5",
    "yoga-layout": "^3.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.59.1",
    "@sentry/cli": "^3.4.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-jest": "^29.7.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "knip": "^6.12.1",
    "patch-package": "^8.0.1",
    "qrcode": "^1.5.4",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nfc-manager"
        ]
      }
    }
  },
  "private": true
}
