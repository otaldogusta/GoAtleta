{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "expo-modules-core": [
        "./node_modules/expo/node_modules/expo-modules-core"
      ],
      "expo-modules-core/*": [
        "./node_modules/expo/node_modules/expo-modules-core/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "tmp/**",
    "supabase/functions/**",
    "dist/**",
    "coverage/**"
  ]
}
