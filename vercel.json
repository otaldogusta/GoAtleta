{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run web",
  "installCommand": "npm install",
  "framework": null,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.goatleta.com"
        }
      ],
      "destination": "https://goatleta.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/oauth/google-drive/callback",
      "destination": "https://hgmdpetpwclucvquoklv.supabase.co/functions/v1/document-drive-oauth"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
